[sub_resource type="GDScript" id="GDScript_otyy5"]
script/source = "extends Node2D

var achievement_panel = preload(\"res://scenes/achievement_panel.tscn\")
var achv_themes = [
	load(\"res://assets/achvlevels/0.tres\"),
	load(\"res://assets/achvlevels/1.tres\"),
	load(\"res://assets/achvlevels/2.tres\"),
	load(\"res://assets/achvlevels/3.tres\"),
	load(\"res://assets/achvlevels/4.tres\")
]

func _ready() -> void:
	get_viewport().size_changed.connect(_on_viewport_size_changed)
	call_deferred(\"_update_ui_scale\")
	_populate_achievements()
	_update_progress()

func _on_viewport_size_changed() -> void:
	_update_ui_scale()

func _update_ui_scale() -> void:
	var viewport_size = get_viewport_rect().size
	var viewport_height = viewport_size.y
	var viewport_width = viewport_size.x
	
	# 判断是否为竖屏模式
	var is_portrait = viewport_height > viewport_width
	
	# 标题字体
	var title_font_size: int
	if is_portrait:
		title_font_size = max(20, int(viewport_width * 0.055))
	else:
		title_font_size = max(25, int(viewport_height * 0.045))
	
	var title_label = $CanvasLayer/ColorRect/MarginContainer/VBoxContainer/HBoxContainer2/TitleLabel
	var title_settings = LabelSettings.new()
	title_settings.font = title_label.label_settings.font
	title_settings.font_size = title_font_size
	title_label.label_settings = title_settings
	
	# 按钮字体和大小
	var button_font_size: int
	var button_height: int
	var button_width: int
	
	if is_portrait:
		button_font_size = max(12, int(viewport_width * 0.032))
		button_height = max(30, int(viewport_height * 0.04))
		button_width = max(70, int(viewport_width * 0.18))
	else:
		button_font_size = max(14, int(viewport_height * 0.022))
		button_height = max(30, int(viewport_height * 0.045))
		button_width = max(75, int(viewport_size.x * 0.08))
	
	for btn_name in [\"GlobalBtn\", \"BackBtn\"]:
		var btn = $CanvasLayer/ColorRect/MarginContainer/VBoxContainer/HBoxContainer2/PlaceHolder3.get_node(btn_name)
		btn.custom_minimum_size = Vector2(button_width, button_height)
		btn.pivot_offset = Vector2(button_width, button_height) / 2.0
		btn.begin_bulk_theme_override()
		btn.add_theme_font_size_override(\"font_size\", button_font_size)
		btn.end_bulk_theme_override()
	
	# 进度标签字体
	var label_font_size: int
	if is_portrait:
		label_font_size = max(12, int(viewport_width * 0.032))
	else:
		label_font_size = max(14, int(viewport_height * 0.022))
	
	var progress_label = $CanvasLayer/ColorRect/MarginContainer/VBoxContainer/HBoxContainer/Label
	var label_settings = LabelSettings.new()
	label_settings.font = progress_label.label_settings.font
	label_settings.font_size = label_font_size
	progress_label.label_settings = label_settings
	
	# 等级标签字体
	var level_font_size: int
	if is_portrait:
		level_font_size = max(14, int(viewport_width * 0.038))
	else:
		level_font_size = max(16, int(viewport_height * 0.025))
	
	for i in range(5):
		var level_label = $CanvasLayer/ColorRect/MarginContainer/VBoxContainer/ScrollContainer/ACHVS.get_node(\"Label\" + (\"\" if i == 0 else str(i + 1)))
		var level_settings = LabelSettings.new()
		level_settings.font = level_label.label_settings.font if level_label.label_settings else null
		level_settings.font_size = level_font_size
		level_label.label_settings = level_settings

func _populate_achievements() -> void:
	var gained_achvs = EventManager.propertydata_ins.status[PropertyData.Types.ACHV]
	print(\"成就页面 - 已获得的成就: \", gained_achvs)
	print(\"成就数量: \", gained_achvs.size())
	if gained_achvs.size() > 0:
		print(\"第一个成就类型: \", typeof(gained_achvs[0]))
	
	# 按等级分组成就
	for grade in range(5):
		var container = $CanvasLayer/ColorRect/MarginContainer/VBoxContainer/ScrollContainer/ACHVS.get_node(\"SC\" + str(grade) + \"/VBoxContainer\")
		
		# 收集该等级的所有成就，分为已获得和未获得
		var gained_list = []
		var not_gained_list = []
		
		for achv_id_str in EventManager.achievement_ins._achievements:
			var achv = EventManager.achievement_ins._achievements[achv_id_str]
			if int(achv[\"grade\"]) == grade:
				var achv_id = int(achv_id_str)
				# 适配float类型的成就ID：检查int和float两种形式
				var is_gained = achv_id in gained_achvs or float(achv_id) in gained_achvs
				if is_gained:
					gained_list.append({\"id\": achv_id_str, \"data\": achv})
				else:
					not_gained_list.append({\"id\": achv_id_str, \"data\": achv})
		
		# 先添加已获得的成就
		for item in gained_list:
			var panel = achievement_panel.instantiate()
			panel.theme = achv_themes[grade]
			
			var name_label = panel.get_node(\"MarginContainer/VBoxContainer/name\")
			name_label.text = item[\"data\"][\"name\"]
			
			var gained_label = panel.get_node(\"MarginContainer/VBoxContainer/gained\")
			gained_label.text = \"已获得\"
			
			container.add_child(panel)
		
		# 再添加未获得的成就
		for item in not_gained_list:
			var panel = achievement_panel.instantiate()
			panel.theme = achv_themes[grade]
			
			var name_label = panel.get_node(\"MarginContainer/VBoxContainer/name\")
			name_label.text = item[\"data\"][\"name\"]
			
			var gained_label = panel.get_node(\"MarginContainer/VBoxContainer/gained\")
			gained_label.text = \"未获得\"
			
			container.add_child(panel)

func _update_progress() -> void:
	var progress_bar = $CanvasLayer/ColorRect/MarginContainer/VBoxContainer/HBoxContainer/RACHV
	var rachv = EventManager.propertydata_ins.status.get(PropertyData.Types.RACHV, 0.0)
	progress_bar.value = rachv * 100.0


func _on_back_btn_pressed() -> void:
	TransitionManager.transition_to(\"res://scenes/Menu.tscn\")


func _on_global_btn_pressed() -> void:
	NotificationManager.show_notification(\"排行系统施工中……\")
"

